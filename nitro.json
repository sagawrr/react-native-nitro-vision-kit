{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitrovisionkit"],
  "ios": {
    "iosModuleName": "NitroVisionKit"
  },
  "android": {
    "androidNamespace": ["nitrovisionkit"],
    "androidCxxLibName": "NitroVisionKit"
  },
  "autolinking": {
    "VisionKitFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridVisionKit"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridVisionKit"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
