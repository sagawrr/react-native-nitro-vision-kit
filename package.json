{
  "name": "react-native-nitro-vision-kit",
  "version": "0.2.2",
  "description": "Subject segmentation and image classification for React Native. Vision on iOS, ML Kit on Android. Built with Nitro Modules.",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "nitrogen/generated",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "ios",
    "nitro.json",
    "NitroVisionKit.podspec",
    "react-native.config.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!**/android/build",
    "!**/android/.cxx",
    "!**/Pods",
    "!**/.DS_Store"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,tsx}\" --fix",
    "lint-ci": "eslint \"src/**/*.{js,ts,tsx}\" --max-warnings 0",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\"",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "nitro-modules",
    "nitro",
    "vision",
    "background-removal",
    "image-classification",
    "subject-segmentation",
    "mlkit",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sagawrr/react-native-nitro-vision-kit.git"
  },
  "author": "sagawrr <sagawrr@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sagawrr/react-native-nitro-vision-kit/issues"
  },
  "homepage": "https://github.com/sagawrr/react-native-nitro-vision-kit#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "0.86.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/react": "^19.2.15",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "nitrogen": "*",
    "prettier": "^3.8.3",
    "react": "19.2.8",
    "react-native": "0.86.0",
    "react-native-nitro-modules": "0.36.1",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.75.0",
    "react-native-nitro-modules": "^0.35.10"
  },
  "codegenConfig": {
    "name": "NitroVisionKitSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.margelo.nitro.nitrovisionkit"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  }
}
